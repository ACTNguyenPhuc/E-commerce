# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_db
DB_USER=root
DB_PASSWORD=root

# JWT
JWT_SECRET=change-me-please-use-a-very-long-random-string-for-production-at-least-256-bits

# CORS
